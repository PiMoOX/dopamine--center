---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';  // ← این خط رو حتماً داشته باش
import Services from '../components/Services.astro';
import Courses from '../components/Courses.astro';
import Podcast from '../components/Podcast.astro';
import Quote from '../components/Quote.astro';
import Journal from '../components/Journal.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout>
  <Header />
  
  <!-- ===== هیرو (همون قبلی) ===== -->
  <Hero />  <!-- ← این خط رو حتماً داشته باش -->
  
  <!-- ===== اسلایدر بنر (زیر هیرو) ===== -->
  <section class="banner-slider py-8 px-4 bg-gradient-to-b from-white to-pink-50">
    <div class="max-w-6xl mx-auto relative" x-data="{ active: 0 }">
      <div class="relative overflow-hidden rounded-2xl shadow-2xl aspect-[16/9]">
        <!-- اسلاید ۱ -->
        <div class="absolute inset-0 transition-opacity duration-700 ease-in-out" 
             :class="{ 'opacity-100': active === 0, 'opacity-0': active !== 0 }">
          <img src="/images/teen-behavior-banner.png" alt="" class="w-full h-full object-cover">
        </div>
        <!-- اسلاید ۲ -->
        <div class="absolute inset-0 transition-opacity duration-700 ease-in-out" 
             :class="{ 'opacity-100': active === 1, 'opacity-0': active !== 1 }">
          <img src="/images/banner-2.jpg" alt="" class="w-full h-full object-cover">
        </div>
        <!-- اسلاید ۳ -->
        <div class="absolute inset-0 transition-opacity duration-700 ease-in-out" 
             :class="{ 'opacity-100': active === 2, 'opacity-0': active !== 2 }">
          <img src="/images/banner-3.jpg" alt="" class="w-full h-full object-cover">
        </div>
        <!-- اسلاید ۴ -->
        <div class="absolute inset-0 transition-opacity duration-700 ease-in-out" 
             :class="{ 'opacity-100': active === 3, 'opacity-0': active !== 3 }">
          <img src="/images/banner-4.jpg" alt="" class="w-full h-full object-cover">
        </div>

        <!-- دکمه‌های قبلی و بعدی -->
        <button @click="active = (active > 0) ? active - 1 : 3" 
                class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/30 hover:bg-white/50 text-white p-3 rounded-full shadow-lg backdrop-blur-sm transition-all z-10">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button @click="active = (active < 3) ? active + 1 : 0" 
                class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/30 hover:bg-white/50 text-white p-3 rounded-full shadow-lg backdrop-blur-sm transition-all z-10">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>

        <!-- نقاط راهنما -->
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-3 z-10">
          <button @click="active = 0" 
                  class="w-3 h-3 rounded-full transition-all duration-300"
                  :class="{ 'bg-white w-8': active === 0, 'bg-white/50': active !== 0 }"></button>
          <button @click="active = 1" 
                  class="w-3 h-3 rounded-full transition-all duration-300"
                  :class="{ 'bg-white w-8': active === 1, 'bg-white/50': active !== 1 }"></button>
          <button @click="active = 2" 
                  class="w-3 h-3 rounded-full transition-all duration-300"
                  :class="{ 'bg-white w-8': active === 2, 'bg-white/50': active !== 2 }"></button>
          <button @click="active = 3" 
                  class="w-3 h-3 rounded-full transition-all duration-300"
                  :class="{ 'bg-white w-8': active === 3, 'bg-white/50': active !== 3 }"></button>
        </div>
      </div>
    </div>
  </section>

  <div class="glow-divider"></div>
  <Services />
  <Courses />
  <Podcast />
  <Quote />
  <Journal />
  <About />
  <Contact />
  <Footer />
</BaseLayout>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('slider', () => ({
      active: 0,
      init() {
        setInterval(() => {
          this.active = (this.active < 3) ? this.active + 1 : 0;
        }, 5000);
      }
    }));
  });
</script>