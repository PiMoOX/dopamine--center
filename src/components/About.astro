---
// بخش درباره ما
import { aboutStats } from '../lib/content';
---

<section id="about" class="py-24 px-6" style="background:#fff">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
    <div class="reveal">
      <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color:#f43f6b">درباره ما</p>
      <h2 class="text-3xl md:text-4xl font-black leading-tight mb-6" style="color:#1a1a2e">ما به رشد<br />واقعی اعتقاد داریم</h2>
      <p class="text-sm leading-relaxed mb-5" style="color:#6b6b8e">دوپامین سنتر با هدف دسترس‌پذیر کردن دانش روانشناسی برای همه فارسی‌زبانان تأسیس شده. ما باور داریم هر کسی می‌تونه با ابزار درست، زندگی بهتری بسازه.</p>
      <p class="text-sm leading-relaxed" style="color:#6b6b8e">تیم ما از روانشناسان، مربیان زندگی و تولیدکنندگان محتواست که تجربه‌شون رو در قالب مشاوره، آموزش و پادکست با شما به اشتراک می‌ذارن.</p>
    </div>
    <div class="reveal grid grid-cols-2 gap-4" style="transition-delay:.15s">
      {aboutStats.map(stat => {
        let cls = 'glass-card';
        let style = '';
        let valueColor = '#f43f6b';
        let labelColor = '#6b6b8e';

        if (stat.dark) {
          cls = 'dark-section';
          valueColor = '#ff85a1';
          labelColor = '#9b9bb8';
        } else if (stat.bgTint) {
          style = 'background:rgba(255,214,224,0.35)';
        }

        return (
          <div class={`${cls} rounded-2xl p-6 text-center`} style={style}>
            <p class="text-3xl font-black" style={`color:${valueColor}`}>{stat.value}</p>
            <p class="text-sm mt-1" style={`color:${labelColor}`}>{stat.label}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
