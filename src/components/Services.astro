---
// بخش خدمات با تصاویر و رنگ‌های هماهنگ
---

<section id="services" class="py-24 px-6" style="background:#fff">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14 reveal">
      <p class="text-xs font-bold tracking-widest uppercase mb-3" style="color:#f43f6b">خدمات ما</p>
      <h2 class="text-3xl md:text-4xl font-black" style="color:#1a1a2e">چطور می‌تونیم کمک کنیم؟</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-7">

      <!-- مشاوره فردی — لاوندر -->
      <div class="glass-card rounded-2xl overflow-hidden reveal">
        <div class="h-48 relative overflow-hidden" style="box-shadow:inset 0 -18px 28px rgba(244,100,130,0.15);">
          <img src="https://images.unsplash.com/photo-1573497620053-ea5300f94f21?w=600&q=80&auto=format&fit=crop" alt="مشاوره فردی" class="w-full h-full object-cover" style="transition:transform .5s ease;" onmouseover="this.style.transform='scale(1.06)'" onmouseout="this.style.transform='scale(1)'"/>
          <div style="position:absolute;inset:0;background:linear-gradient(160deg,rgba(167,139,250,0.32) 0%,rgba(244,63,107,0.28) 100%);pointer-events:none"></div>
          <div style="position:absolute;bottom:0;left:0;right:0;height:60%;background:linear-gradient(to top,rgba(255,255,255,0.85),transparent);pointer-events:none"></div>
          <div style="position:absolute;bottom:14px;right:14px;width:42px;height:42px;border-radius:12px;background:rgba(167,139,250,0.18);backdrop-filter:blur(8px);border:1px solid rgba(167,139,250,0.35);display:flex;align-items:center;justify-content:center;">
            <svg class="w-5 h-5" fill="none" stroke="#a78bfa" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>
          </div>
        </div>
        <div class="p-7">
          <span style="background:rgba(167,139,250,0.12);color:#7c3aed;border:1px solid rgba(167,139,250,0.3);font-size:.7rem;font-weight:700;padding:3px 12px;border-radius:99px;">مشاوره</span>
          <h3 class="text-xl font-black mt-4 mb-2" style="color:#1a1a2e">مشاوره فردی</h3>
          <p class="text-sm leading-relaxed mb-6" style="color:#6b6b8e">جلسات خصوصی با متخصصین مجرب برای حل چالش‌های شخصی، روابط و مسیر زندگی.</p>
          <a href="#contact" class="inline-flex items-center gap-1.5 text-sm font-bold transition-colors" style="color:#a78bfa;">رزرو جلسه <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
        </div>
      </div>

      <!-- دوره‌ها — تیل -->
      <div class="glass-card rounded-2xl overflow-hidden reveal" style="transition-delay:.1s">
        <div class="h-48 relative overflow-hidden" style="box-shadow:inset 0 -18px 28px rgba(244,100,130,0.15);">
          <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=600&q=80&auto=format&fit=crop" alt="دوره‌های آموزشی" class="w-full h-full object-cover" style="transition:transform .5s ease;" onmouseover="this.style.transform='scale(1.06)'" onmouseout="this.style.transform='scale(1)'"/>
          <div style="position:absolute;inset:0;background:linear-gradient(160deg,rgba(52,211,153,0.28) 0%,rgba(56,189,248,0.25) 100%);pointer-events:none"></div>
          <div style="position:absolute;bottom:0;left:0;right:0;height:60%;background:linear-gradient(to top,rgba(255,255,255,0.85),transparent);pointer-events:none"></div>
          <div style="position:absolute;bottom:14px;right:14px;width:42px;height:42px;border-radius:12px;background:rgba(52,211,153,0.15);backdrop-filter:blur(8px);border:1px solid rgba(52,211,153,0.3);display:flex;align-items:center;justify-content:center;">
            <svg class="w-5 h-5" fill="none" stroke="#34d399" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
        </div>
        <div class="p-7">
          <span style="background:rgba(52,211,153,0.1);color:#059669;border:1px solid rgba(52,211,153,0.28);font-size:.7rem;font-weight:700;padding:3px 12px;border-radius:99px;">آموزش</span>
          <h3 class="text-xl font-black mt-4 mb-2" style="color:#1a1a2e">دوره‌های آموزشی</h3>
          <p class="text-sm leading-relaxed mb-6" style="color:#6b6b8e">برنامه‌های جامع برای یادگیری مهارت‌های زندگی، مدیریت احساسات و رشد شخصی.</p>
          <a href="#courses" class="inline-flex items-center gap-1.5 text-sm font-bold transition-colors" style="color:#34d399;">مشاهده دوره‌ها <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
        </div>
      </div>

      <!-- پادکست — آمبر -->
      <div class="glass-card rounded-2xl overflow-hidden reveal" style="transition-delay:.2s">
        <div class="h-48 relative overflow-hidden" style="box-shadow:inset 0 -18px 28px rgba(244,100,130,0.15);">
          <img src="https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=600&q=80&auto=format&fit=crop" alt="پادکست" class="w-full h-full object-cover" style="transition:transform .5s ease;" onmouseover="this.style.transform='scale(1.06)'" onmouseout="this.style.transform='scale(1)'"/>
          <div style="position:absolute;inset:0;background:linear-gradient(160deg,rgba(251,191,36,0.28) 0%,rgba(249,115,22,0.25) 100%);pointer-events:none"></div>
          <div style="position:absolute;bottom:0;left:0;right:0;height:60%;background:linear-gradient(to top,rgba(255,255,255,0.85),transparent);pointer-events:none"></div>
          <div style="position:absolute;bottom:14px;right:14px;width:42px;height:42px;border-radius:12px;background:rgba(251,191,36,0.15);backdrop-filter:blur(8px);border:1px solid rgba(251,191,36,0.3);display:flex;align-items:center;justify-content:center;">
            <svg class="w-5 h-5" fill="none" stroke="#f59e0b" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
          </div>
        </div>
        <div class="p-7">
          <span style="background:rgba(251,191,36,0.1);color:#b45309;border:1px solid rgba(251,191,36,0.3);font-size:.7rem;font-weight:700;padding:3px 12px;border-radius:99px;">پادکست رایگان</span>
          <h3 class="text-xl font-black mt-4 mb-2" style="color:#1a1a2e">پادکست</h3>
          <p class="text-sm leading-relaxed mb-6" style="color:#6b6b8e">محتوای صوتی رایگان درباره روانشناسی، انگیزه، موفقیت و بهبود کیفیت زندگی.</p>
          <a href="#podcast" class="inline-flex items-center gap-1.5 text-sm font-bold transition-colors" style="color:#f59e0b;">گوش بده <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
        </div>
      </div>

    </div>
  </div>
</section>
